{
  "functions": {
    "api/**/*.js": { "runtime": "@vercel/node@5.1.0" }
  },
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/api/auth/callback/google", "destination": "/api/auth/google" },
    { "source": "/api/auth/callback/github", "destination": "/api/auth/github" },
    { "source": "/api/skills", "destination": "/api/tasks?_route=skills" },
    { "source": "/api/v1/chat/completions", "destination": "/api/v1/chat/completions" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/signin", "destination": "/auth/signin.html" },
    { "source": "/auth/signin", "destination": "/auth/signin.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    }
  ],
  "outputDirectory": "public"
}
